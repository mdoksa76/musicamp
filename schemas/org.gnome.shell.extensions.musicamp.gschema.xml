<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.musicamp" path="/org/gnome/shell/extensions/musicamp/">
    
    <key name="loop-enabled" type="b">
      <default>true</default>
      <summary>Enable loop mode</summary>
      <description>When enabled, playlist will loop continuously</description>
    </key>
    
    <key name="shuffle-enabled" type="b">
      <default>false</default>
      <summary>Enable shuffle mode</summary>
      <description>When enabled, tracks will play in random order</description>
    </key>
    
    <key name="volume" type="d">
      <default>0.8</default>
      <range min="0.0" max="1.0"/>
      <summary>Playback volume</summary>
      <description>Volume level from 0.0 (mute) to 1.0 (max)</description>
    </key>
    
    <key name="music-playlist" type="s">
      <default>'[]'</default>
      <summary>Music playlist</summary>
      <description>JSON array containing playlist tracks with name, uri, and enabled status</description>
    </key>
    
  </schema>
</schemalist>